					},
					{
						"key": "Authorization",
						"value": "Bearer {{accessToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"ingredients\": [\n    {\n      \"productId\": 1,\n      \"unitId\": 1,\n      \"quantity\": 200\n    },\n    {\n      \"productId\": 2,\n      \"unitId\": 2,\n      \"quantity\": 3\n    }\n  ],\n  \"additionalProducts\": [\"sól\", \"pieprz\"],\n  \"title\": \"Makaron carbonara\",\n  \"description\": \"Klasyczny włoski makaron carbonara\",\n  \"instructions\": \"1. Ugotuj makaron\\n2. Podsmaż boczek\\n3. Wymieszaj jajka z parmezanem\\n4. Połącz wszystko\",\n  \"servings\": 4,\n  \"preparationTimeMinutes\": 30,\n  \"calories\": 650,\n  \"protein\": 25,\n  \"carbohydrates\": 70,\n  \"fats\": 28\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/receipts",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"receipts"
					]
				},
				"description": "Ręczne tworzenie przepisu z określonymi składnikami i instrukcjami"
			},
			"response": []
		},
